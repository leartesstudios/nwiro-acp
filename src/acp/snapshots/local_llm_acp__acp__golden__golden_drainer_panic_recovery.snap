---
source: src/acp/golden.rs
expression: normalize(capture.frames())
---
[
  {
    "id": 1,
    "jsonrpc": "2.0",
    "result": {
      "serverCapabilities": {
        "session": {
          "cancel": true,
          "prompt": true,
          "setConfigOption": true
        }
      },
      "serverInfo": {
        "name": "local-llm-acp",
        "version": "[version]"
      }
    }
  },
  {
    "id": 2,
    "jsonrpc": "2.0",
    "result": {
      "sessionId": "[session-id]"
    }
  },
  {
    "id": 3,
    "jsonrpc": "2.0",
    "result": {}
  },
  {
    "error": {
      "code": -32000,
      "message": "[error-message]"
    },
    "id": 4,
    "jsonrpc": "2.0"
  },
  {
    "jsonrpc": "2.0",
    "method": "session/update",
    "params": {
      "sessionId": "[session-id]",
      "update": {
        "content": {
          "text": "hi",
          "type": "text"
        },
        "sessionUpdate": "agent_message_chunk"
      }
    }
  },
  {
    "id": 5,
    "jsonrpc": "2.0",
    "result": {
      "stopReason": "end_turn"
    }
  }
]
